# =================================================================
# ASTRAFLOW ENVIRONMENT CONFIGURATION
# =================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)
# =================================================================

# -----------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# -----------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_not_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard

# Frontend uses anon key (safe for client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------
# ASTRAFLOW SECURITY (Required)
# -----------------------------------------------------------------
# Generate a secure 256-bit key using: openssl rand -hex 32
ASTRAFLOW_MASTER_KEY=generate_using_openssl_rand_hex_32_command

# -----------------------------------------------------------------
# BACKEND API CONFIGURATION
# -----------------------------------------------------------------
# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development  # or 'production'

# -----------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------
# Comma-separated list of allowed origins (NO SPACES)
# Development default
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Production example (replace with your actual domain):
# ALLOWED_ORIGINS=https://astraflow.yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------
# FRONTEND API CONFIGURATION
# -----------------------------------------------------------------
# Backend API URL that frontend will call
VITE_BACKEND_URL=http://localhost:8000

# Production example:
# VITE_BACKEND_URL=https://api.astraflow.yourdomain.com

# -----------------------------------------------------------------
# OPTIONAL: DATABASE CONNECTION POOLS
# -----------------------------------------------------------------
# Connection pool limits (optional - has defaults)
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------
# OPTIONAL: DEBUGGING & TESTING
# -----------------------------------------------------------------
# Set to "true" to use mock database (for testing without Supabase)
USE_MOCK_DB=false

# Enable debug mode in frontend (bypasses auth)
VITE_ASTRA_DEBUG_MODE=false

# -----------------------------------------------------------------
# OPTIONAL: MONITORING & LOGGING
# -----------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# -----------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------
# 1. NEVER commit .env to git (use .env.example for documentation)
# 2. Rotate ASTRAFLOW_MASTER_KEY if compromised
# 3. Use different keys for dev/staging/production
# 4. Keep SUPABASE_SERVICE_ROLE_KEY secret (never expose to frontend)
# 5. Frontend only uses VITE_* variables (they're safe to expose)
# =================================================================
